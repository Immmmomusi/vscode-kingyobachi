{
  "name": "vscode-kingyobachi",
  "displayName": "Kingyobachi - Goldfish Bowl",
  "description": "A relaxing pixel-art goldfish bowl to watch while coding",
  "version": "0.1.0",
  "publisher": "Immmmomusi",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Immmmomusi/vscode-kingyobachi.git"
  },
  "bugs": {
    "url": "https://github.com/Immmmomusi/vscode-kingyobachi/issues"
  },
  "homepage": "https://github.com/Immmmomusi/vscode-kingyobachi#readme",
  "keywords": [
    "goldfish",
    "aquarium",
    "kingyobachi",
    "金魚",
    "金魚鉢",
    "pixel-art",
    "relaxing",
    "pet"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "kingyobachi.aquariumView",
          "name": "vscode-kingyobachi",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "kingyobachi.feed",
        "title": "Kingyobachi: Feed",
        "icon": "$(heart)"
      },
      {
        "command": "kingyobachi.addFish",
        "title": "Kingyobachi: Add Fish",
        "icon": "$(add)"
      },
      {
        "command": "kingyobachi.removeFish",
        "title": "Kingyobachi: Remove Fish",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "kingyobachi",
      "properties": {
        "kingyobachi.waterColorTop": {
          "type": "string",
          "default": "#0a2a4a",
          "description": "Water color (top)"
        },
        "kingyobachi.waterColorBottom": {
          "type": "string",
          "default": "#0d1b2a",
          "description": "Water color (bottom)"
        },
        "kingyobachi.sandColor": {
          "type": "string",
          "default": "#3a2f1a",
          "description": "Sand color"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "kingyobachi.feed",
          "when": "view == kingyobachi.aquariumView",
          "group": "navigation"
        },
        {
          "command": "kingyobachi.addFish",
          "when": "view == kingyobachi.aquariumView",
          "group": "navigation"
        },
        {
          "command": "kingyobachi.removeFish",
          "when": "view == kingyobachi.aquariumView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
