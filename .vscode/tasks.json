{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "label": "npm: dev",
      "group": "build",
      "problemMatcher": {
        "owner": "webpack",
        "severity": "error",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "ERROR in (.+)\\((\\d+),(\\d+)\\)\\s*$\\n\\s*TS\\d+:\\s*(.+)",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "webpack .+ compiled",
          "endsPattern": "compiled (successfully|with \\d+ error)"
        }
      }
    },
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "webpack",
        "severity": "error",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "ERROR in (.+)\\((\\d+),(\\d+)\\)",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 0
        }
      }
    }
  ]
}
